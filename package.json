{
  "name": "muster",
  "version": "0.1.0",
  "private": true,
  "description": "Muster — Decentralized P2P community communication platform",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev:web": "pnpm --filter @muster/web dev",
    "dev:node": "pnpm --filter @muster/node dev",
    "build": "pnpm --filter './packages/**' build && pnpm --filter './apps/**' build",
    "test": "pnpm --filter './packages/**' test",
    "clean": "find . -name 'dist' -not -path '*/node_modules/*' | xargs rm -rf",
    "postinstall": "node scripts/fix-webrtc-stub.js"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "overrides": {
      "@ipshipyard/node-datachannel": "npm:empty-module@*",
      "node-datachannel": "npm:empty-module@*",
      "@multiformats/multiaddr": "^12.0.0"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
