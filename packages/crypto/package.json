{
  "name": "@muster/crypto",
  "version": "0.1.0",
  "description": "Muster cryptographic utilities — key generation, signing, encryption",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./e2e": {
      "import": "./dist/e2e.js",
      "types": "./dist/e2e.d.ts",
      "default": "./dist/e2e.js"
    }
  },
  "scripts": {
    "build": "npx tsc --project tsconfig.json",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules ../../node_modules/.bin/jest"
  },
  "dependencies": {
    "@noble/ciphers": "^0.5.3",
    "@noble/curves": "1.9.7",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  }
}