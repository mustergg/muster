{
  "name": "@muster/core",
  "version": "0.1.0",
  "description": "Muster P2P engine — libp2p, GossipSub, DHT, peer management",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev":   "tsc --watch"
  },
  "dependencies": {
    "@muster/crypto":              "workspace:*",
    "@muster/protocol":            "workspace:*",
    "@libp2p/websockets":          "*",
    "@libp2p/bootstrap":           "*",
    "@libp2p/kad-dht":             "*",
    "@libp2p/identify":            "*",
    "@libp2p/noise":               "*",
    "@libp2p/peer-id":             "*",
    "@chainsafe/libp2p-gossipsub": "*",
    "@chainsafe/libp2p-yamux":     "*",
    "libp2p":                      "*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript":  "^5.4.5"
  }
}