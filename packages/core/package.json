{
  "name": "@muster/core",
  "version": "0.1.0",
  "description": "Muster P2P engine — libp2p, GossipSub, DHT, peer management",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev":   "tsc --watch"
  },
  "dependencies": {
    "@muster/crypto":   "workspace:*",
    "@muster/protocol": "workspace:*",
    "@libp2p/websockets":          "^8.0.1",
    "@libp2p/webrtc":              "^4.0.0",
    "@libp2p/bootstrap":           "^10.0.0",
    "@libp2p/kad-dht":             "^12.0.0",
    "@chainsafe/libp2p-gossipsub": "^13.0.0",
    "@libp2p/identify":            "^2.0.0",
    "@libp2p/noise":               "^15.0.0",
    "@libp2p/yamux":               "^6.0.0",
    "@libp2p/peer-id":             "^4.0.0",
    "libp2p":                      "^1.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript":  "^5.4.5"
  }
}
