{
  "name": "@muster/db",
  "version": "0.1.0",
  "description": "Muster distributed database layer — OrbitDB + Helia stores",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "npx tsc --project tsconfig.json",
    "dev":   "npx tsc --watch --project tsconfig.json"
  },
  "dependencies": {
    "@muster/crypto":   "workspace:*",
    "@muster/protocol": "workspace:*",
    "@orbitdb/core":    "^2.4.0",
    "helia":            "^5.0.0",
    "blockstore-core":  "^5.0.0",
    "blockstore-fs":    "^2.0.0",
    "datastore-core":   "^10.0.0",
    "datastore-fs":     "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript":  "^5.4.5"
  }
}
